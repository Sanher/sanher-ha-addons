diff --git a/src/utils/base-path.ts b/src/utils/base-path.ts
new file mode 100644
index 0000000..0b5ee86
--- /dev/null
+++ b/src/utils/base-path.ts
@@ -0,0 +1,40 @@
+declare global {
+  interface Window {
+    __OMNITOOLS_BASE_PATH__?: string;
+  }
+}
+
+function normalizeBasePath(basePath?: string): string | null {
+  if (!basePath) {
+    return null;
+  }
+
+  const trimmed = basePath.trim();
+
+  if (!trimmed) {
+    return null;
+  }
+
+  return trimmed.endsWith('/') ? trimmed : `${trimmed}/`;
+}
+
+export function getRuntimeBasePath(): string {
+  if (typeof window === 'undefined') {
+    return '/';
+  }
+
+  return normalizeBasePath(window.__OMNITOOLS_BASE_PATH__) || '/';
+}
+
+export function getRouterBasename(): string {
+  const basePath = getRuntimeBasePath();
+
+  return basePath === '/' ? basePath : basePath.replace(/\/$/, '');
+}
+
+export function withBasePath(path: string): string {
+  const normalizedPath = path.replace(/^\/+/, '');
+  const basePath = getRuntimeBasePath();
+
+  return normalizedPath ? `${basePath}${normalizedPath}` : basePath;
+}
